APP_HOST=0.0.0.0
APP_PORT=8000
APP_NAME="N10 OIDC Demo"
APP_ENV=development

KEYCLOAK_BASE_URL=https://keycloak.example.org
KEYCLOAK_REALM=demo
KEYCLOAK_CLIENT_ID=demo-web
KEYCLOAK_BROKER_ALIAS=globus

# For local development against self-signed Keycloak certs only.
KEYCLOAK_VERIFY_TLS=true

# Demo mode: the backend accepts the frontend's ID token as the bearer token.
# If your token's "aud" claim does not equal KEYCLOAK_CLIENT_ID, set this to false.
OIDC_VERIFY_AUDIENCE=true
